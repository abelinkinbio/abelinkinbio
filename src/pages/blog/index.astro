---
// ─────────────────────────────────────────────────────────────
// Blog listing — all long-form posts, sorted newest first
// ─────────────────────────────────────────────────────────────

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Field Notes" activeNav="blog">
  <section class="panel" style="margin-bottom: var(--space-xl);">
    <span class="panel-label">all notes</span>
    <h1 style="margin-bottom: var(--space-lg);">Field Notes</h1>

    <div class="stack">
      {sorted.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="card" style="text-decoration: none;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: var(--space-sm);">
            <span class="card-title">{post.data.title}</span>
          </div>
          <p class="card-description" style="margin-bottom: var(--space-sm);">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (
                <span class="tag tag-purple">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    {sorted.length === 0 && (
      <p style="color: var(--color-muted);">No posts yet. They'll show up here when you add markdown files to <code>src/content/blog/</code>.</p>
    )}
  </section>
</BaseLayout>
